(***************************************************************************)
(* PlusCal source for the ADR-040 §2 Live-Adapter Circuit Breaker.         *)
(*                                                                         *)
(* This is the READABLE source. The canonical machine-checkable spec is    *)
(* in ``breaker.tla`` — generated by ``java -cp tla2tools.jar              *)
(* tlc2.pcal.trans breaker.pcal`` OR hand-derived from this file. See      *)
(* ``run-tlc.sh`` for the toolchain pin.                                   *)
(*                                                                         *)
(* Models ``.claude/hooks/_lib/adapters/live/_breaker.py`` as of 2026-04-16.*)
(* Correspondence table in ``properties-proved.md § Model ↔                *)
(* Implementation``.                                                       *)
(*                                                                         *)
(* Phase D.2 — PLAN-013. Principal QA Architect + Principal Security       *)
(* Engineer (composite).                                                   *)
(***************************************************************************)
--algorithm CircuitBreaker {

variables
  (* Breaker state machine. Mirrors _breaker.py:34-39 enum BreakerState. *)
  breaker_state = "closed",

  (* Rolling count of failures within the last WINDOW_S seconds. Mirrors *)
  (* _breaker.py:109-110 ``self._failures`` deque (we abstract to count  *)
  (* + timestamps list; the sliding window pruner is modeled via ``tick``*)
  (* action shedding entries older than now - WINDOW_S).                 *)
  failures = <<>>,

  (* Monotonic seconds when the breaker last transitioned to "open".     *)
  (* Mirrors _breaker.py:111 ``self._opened_at``. None is represented    *)
  (* as -1 (TLC has no Option type in minimal spec).                    *)
  opened_at = -1,

  (* Set of caller IDs currently in-flight (have passed should_allow but *)
  (* not yet called record_success/record_failure). Cardinality bounded  *)
  (* by MAX_CALLERS via config. Mirrors the ``self._probe_available``    *)
  (* bool in _breaker.py:114-115 (half-open singleton semantics) plus an *)
  (* abstraction of the caller-thread set. In "closed" the cardinality   *)
  (* is unbounded by the breaker itself (at-most-MAX_CALLERS via config);*)
  (* in "half_open" the breaker enforces Cardinality(in_flight) <= 1.    *)
  in_flight = {},

  (* Append-only audit log. ``breaker_opened`` appended on every closed→ *)
  (* open transition. NOTE — the real ``_breaker.py`` code does NOT      *)
  (* CURRENTLY call ``emit_breaker_opened``; the audit helper exists in  *)
  (* audit_emit.py:977 but is not wired. This spec models the INTENDED   *)
  (* contract per ADR-040 §7; the S3 conformance test is EXPECTED to     *)
  (* fail on current code and pass once Gap #3 (PLAN-013 Session-20 log) *)
  (* is closed. This divergence is intentional: the model is the         *)
  (* contract, the test is the drift detector.                           *)
  audit_log = <<>>,

  (* Monotonic clock in seconds. Advanced only by the ``tick`` action.   *)
  now = 0,

  (* Half-open probe availability. Mirrors _breaker.py:115               *)
  (* ``self._probe_available``.                                          *)
  probe_available = FALSE;

define {
  \* Predicate: count of failures within the rolling window ending at `now`.
  FailuresInWindow == Cardinality({ i \in 1..Len(failures) :
                                      failures[i] >= now - WINDOW_S })

  \* Safety: state is one of the three canonical names.
  StateWellFormed == breaker_state \in {"closed", "open", "half_open"}

  \* Auxiliary: "opened_at" is set iff state is "open" OR "half_open".
  OpenedAtInvariant ==
    (breaker_state = "open" => opened_at >= 0) /\
    (breaker_state = "closed" => opened_at = -1)
}

(***************************************************************************)
(* Record a failure event. Mirrors _breaker.py:176-211 record_failure.    *)
(* Simplified: reason is elided — we model only counting+transient.       *)
(* (Permanent "auth_permanent" + non-counting "parse_error" are covered   *)
(* by the impl's branch on reason; we abstract to the transient case.)    *)
(***************************************************************************)
macro RecordFailure() {
  \* Per _breaker.py:188 refresh the state (may transition open→half_open).
  if (breaker_state = "open" /\ (now - opened_at) >= HALF_OPEN_HOLD_S) {
    breaker_state := "half_open";
    probe_available := TRUE;
    failures := <<>>;
  };
  \* Append this failure and prune old entries from the window.
  failures := SelectSeq(Append(failures, now), LAMBDA t: t >= now - WINDOW_S);
  if (breaker_state = "half_open") {
    \* Probe failed → re-open. _breaker.py:202-205.
    breaker_state := "open";
    opened_at := now;
    probe_available := FALSE;
    audit_log := Append(audit_log, [action |-> "breaker_opened",
                                    time   |-> now,
                                    cause  |-> "half_open_probe_failed"]);
  } else if (breaker_state = "closed" /\ Len(failures) >= FAILURE_THRESHOLD) {
    \* Threshold crossed → open. _breaker.py:207-211.
    breaker_state := "open";
    opened_at := now;
    probe_available := FALSE;
    audit_log := Append(audit_log, [action |-> "breaker_opened",
                                    time   |-> now,
                                    cause  |-> "threshold_crossed"]);
  };
}

(***************************************************************************)
(* Record a success. Mirrors _breaker.py:213-232 record_success.          *)
(***************************************************************************)
macro RecordSuccess() {
  if (breaker_state = "half_open") {
    breaker_state := "closed";
    opened_at := -1;
    probe_available := FALSE;
    failures := <<>>;
  };
  \* closed+success is a no-op (slow-drain via window).
  \* open+success is unreachable per should_allow gate; we leave it alone.
}

(***************************************************************************)
(* Refresh the state. Mirrors _breaker.py:257-266 _refresh_state_locked.  *)
(* Split from RecordFailure/RecordSuccess so the liveness property        *)
(* L1 has a pure "time passes → state may transition" action to schedule. *)
(***************************************************************************)
macro RefreshState() {
  if (breaker_state = "open" /\ opened_at >= 0 /\ (now - opened_at) >= HALF_OPEN_HOLD_S) {
    breaker_state := "half_open";
    probe_available := TRUE;
    failures := <<>>;
  };
}

(***************************************************************************)
(* Non-deterministic interleaving of the three caller actions + time pass.*)
(* TLC explores every serialization; concurrency between the shared lock   *)
(* and in-flight set is captured by action interleaving + Cardinality     *)
(* invariants. MAX_CALLERS bounds the model for finite state-space.       *)
(***************************************************************************)
process (Caller \in 1..MAX_CALLERS) {
  Loop: while (now < MaxTime) {
    either {
      \* Start a call (pass should_allow).
      Start:
        RefreshState();
        if (breaker_state = "closed") {
          in_flight := in_flight \cup {self};
          goto Observe;
        } else if (breaker_state = "half_open" /\ probe_available) {
          probe_available := FALSE;
          in_flight := in_flight \cup {self};
          goto Observe;
        };
        \* Else (open, or half_open+probe_consumed) — skip. Loop.
    } or {
      \* Report success for an in-flight call.
      SucceedReport:
        if (self \in in_flight) {
          in_flight := in_flight \ {self};
          RecordSuccess();
        };
    } or {
      \* Report failure for an in-flight call.
      FailReport:
        if (self \in in_flight) {
          in_flight := in_flight \ {self};
          RecordFailure();
        };
    } or {
      \* No-op for this caller this step (allows pure time-pass).
      Skip: skip;
    };
  };
  Observe:
    \* Caller holds in_flight; next loop iteration will SucceedReport or FailReport.
    skip;
    goto Loop;
}

process (Clock = "clock") {
  Tick: while (now < MaxTime) {
    now := now + 1;
    \* Pruning is embedded in RecordFailure; refresh fires opportunistically.
  };
}

}

(***************************************************************************)
(* Properties (encoded as theorems in breaker.tla). PlusCal comments       *)
(* document intent; the canonical TLA+ spec carries the THEOREM blocks.    *)
(*                                                                         *)
(* S1 — threshold → open (safety):                                         *)
(*   []( breaker_state = "closed" /\ FailuresInWindow >= FAILURE_THRESHOLD *)
(*       => <>(breaker_state = "open") )                                   *)
(*                                                                         *)
(* S2 — half-open singleton (safety):                                      *)
(*   []( breaker_state = "half_open" => Cardinality(in_flight) <= 1 )      *)
(*                                                                         *)
(* S3 — state-transition audit (safety):                                   *)
(*   []( (breaker_state' = "open" /\ breaker_state = "closed")             *)
(*       => Len(audit_log') > Len(audit_log)                               *)
(*          /\ audit_log'[Len(audit_log')].action = "breaker_opened" )     *)
(*                                                                         *)
(* L1 — eventually heal (liveness, weak fairness on Tick):                 *)
(*   []( breaker_state = "open"      => <>(breaker_state = "half_open") )  *)
(*   []( breaker_state = "half_open" =>                                    *)
(*       <>(breaker_state \in {"closed","open"}) )                         *)
(***************************************************************************)
