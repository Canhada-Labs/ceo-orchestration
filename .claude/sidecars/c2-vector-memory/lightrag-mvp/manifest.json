{
  "sidecar": {
    "name": "lightrag-mvp",
    "capability_class": "C2",
    "version": "0.1.0",
    "default_tier": "B"
  },
  "isolation": {
    "core_paths_blocked": [
      ".claude/hooks/",
      ".claude/scripts/",
      "SPEC/",
      ".claude/policies/",
      ".github/workflows/"
    ],
    "core_paths_allowlisted_workflow_invokers": [
      ".github/workflows/validate.yml"
    ],
    "import_roots": ["chromadb", "sentence_transformers", "lightrag"],
    "allowed_workflow_invocation_patterns": [
      "^python3? \\.claude/sidecars/c2-vector-memory/lightrag-mvp/boundary_test\\.py($| )"
    ],
    "boundary_test": "boundary_test.py"
  },
  "dependencies": {
    "python": [
      "chromadb==0.4.24",
      "sentence-transformers==2.5.1",
      "lightrag==0.1.0"
    ],
    "system": [],
    "licenses": {
      "chromadb": "Apache-2.0",
      "sentence-transformers": "Apache-2.0",
      "lightrag": "MIT"
    }
  },
  "governance": {
    "kill_switch_env": "CEO_SIDECAR_C2_VECTOR_MEMORY_ENABLED",
    "default_state": "conditional",
    "activation_predicate": "repo_profile=LARGE AND sidecar_installed AND sidecar_running",
    "enable_value": "1",
    "disable_value": "0",
    "explicit_opt_in_required": false,
    "authorizing_adr": "ADR-128",
    "cost_envelope": {
      "per_invocation_tokens": 0,
      "daily_burn_cap": 0,
      "enforcement": "adapter"
    }
  },
  "install": {
    "script": "install.sh",
    "hw_class_check": "disk_2gb",
    "min_python": "3.10",
    "model_pin_sha256": "<hex-populated-at-install>",
    "offline_cache_path": "~/.ceo-rag/models/"
  }
}
