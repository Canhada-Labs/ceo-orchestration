{
  "sidecar": {
    "name": "cryptography-mvp",
    "capability_class": "C1",
    "version": "1.0.0",
    "default_tier": "C",
    "summary": "PEM x509 cert inspection + key-floor verification + SPKI fingerprint extraction. Sole legitimate importer of the `cryptography` Python package per ADR-126 §Part 2 sidecar isolation."
  },
  "isolation": {
    "core_paths_blocked": [
      ".claude/hooks/",
      ".claude/scripts/",
      "SPEC/",
      ".claude/policies/",
      ".github/workflows/"
    ],
    "core_paths_allowlisted_workflow_invokers": [
      ".github/workflows/validate.yml"
    ],
    "import_roots": ["cryptography"],
    "allowed_workflow_invocation_patterns": [
      "^python3? \\.claude/sidecars/c1-crypto/cryptography-mvp/boundary_test\\.py($| )",
      "^python3? \\.claude/sidecars/c1-crypto/cryptography-mvp/sidecar_code/cert_inspector\\.py($| )"
    ],
    "boundary_test": "boundary_test.py"
  },
  "dependencies": {
    "python": ["cryptography>=42.0,<44.0"],
    "system": [],
    "licenses": {
      "cryptography": "Apache-2.0 OR BSD-3-Clause"
    }
  },
  "governance": {
    "kill_switch_env": "CEO_SIDECAR_C1_CRYPTO_CRYPTOGRAPHY_MVP_ENABLED",
    "default_state": "off",
    "activation_predicate": "CEO_FEDERATION_ENABLED=1 AND CEO_FEDERATION_WRITE_ENABLED=1 AND owner_gpg_write_enable_sentinel_valid",
    "enable_value": "1",
    "disable_value": "0",
    "explicit_opt_in_required": true,
    "authorizing_adr": "ADR-129-AMEND-1",
    "cost_envelope": {
      "per_invocation_tokens": 0,
      "daily_burn_cap": 0,
      "enforcement": "adapter"
    }
  },
  "install": {
    "script": "install.sh",
    "hw_class_check": "none"
  }
}
