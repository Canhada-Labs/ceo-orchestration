  "inert_path_rules": [
    {
      "rule_id": "tier-policy-test-pins",
      "pattern": "(^|/)\\.claude/hooks/tests/test_tier_policy_[A-Za-z0-9_]+\\.py$",
      "reason": "S230 INERT class C — framework-installed tier_policy fixture pins (claude-opus-4-1) on the 2026-08-05 fuse; owned by the framework upgrade path (S226 allowlist class), never sent to the API"
    },
    {
      "rule_id": "tests-and-fixtures",
      "pattern": "(^|/)(tests|fixtures)/|(^|/)test_[^/]*\\.py$|_test\\.py$",
      "reason": "test suites + fixtures keep old ids on purpose (negative cases, historical-log replay) — mirrors smoke-install-parity.sh EXEMPT_PATH_RE"
    },
    {
      "rule_id": "backups-shadows-logs",
      "pattern": "\\.bak(\\.|$)|\\.shadow\\.md$|\\.log$|(^|/)\\.git(/|$)",
      "reason": "backups/shadow files/logs are not routing surfaces — mirrors smoke-install-parity.sh EXEMPT_PATH_RE"
    },
    {
      "rule_id": "historical-run-results",
      "pattern": "(^|/)benchmark[^/]*/results/[^/]*\\.json$",
      "reason": "S230 INERT class A — recorded benchmark run outputs, never re-executed"
    },
    {
      "rule_id": "prose-docs",
      "pattern": "\\.(md|markdown|rst|txt)$",
      "reason": "S230 INERT classes B/D — prose/spec/doc text (incl. SKILL.md instructional mentions), no execution path"
    },
    {
      "rule_id": "sql-data",
      "pattern": "\\.sql$",
      "reason": "S230 INERT class E — DDL/seed data strings, not live call sites"
    },
    {
      "rule_id": "by-design-id-carriers",
      "pattern": "\\.claude/scripts/(ceo-cost\\.py|cost-table\\.yaml|budget-summary\\.py|audit-telemetry\\.py|success-receipt\\.py|value-dashboard\\.py|generate-dispatch\\.py|spot-check-findings\\.py|detectors/(wasteful_thinking|overpowered)\\.py|optimizer/model_normalize\\.py)|\\.claude/hooks/_lib/adapters/live/claude\\.py|\\.claude/data/canonical_models\\.json|\\.claude/skills/core/(ai-llm-orchestration/SKILL\\.md|security-and-auth/(SKILL\\.md|benchmarks/owasp-llm-top-10\\.yaml))",
      "reason": "historical pricing/replay tables (incl. ADR-148 canonical_models.json models.dev pricing catalog — retained historical rows for cost reconciliation, S227 rate-card class) + adaptive-thinking known-id table + instructional skill content — mirrors smoke-install-parity.sh ALLOWLIST_RE (every entry justified there)"
    },
    {
      "rule_id": "deprecation-instrument",
      "pattern": "(^|/)(check-model-deprecations\\.py|model-deprecations\\.json|sweep_deprecated_models\\.py|test_check_model_deprecations\\.py|SWEEP-DEPRECATIONS-[A-Za-z0-9-]+\\.txt)$",
      "reason": "the checker, its ledger, its tests and the S230 sweep instrument carry the deprecated ids by design"
    },
    {
      "rule_id": "plan-artifacts",
      "pattern": "(^|/)\\.claude/plans/",
      "reason": "plan/research/staged-bundle records — historical evidence reviewed at ceremony, not live call sites"
    }
  ]
}
