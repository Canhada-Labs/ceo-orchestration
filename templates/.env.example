# =============================================================================
# ceo-orchestration framework — .env template (PLAN-088 god-mode AUTO-USABLE).
#
# Copy to .env (NEVER commit .env itself). Every AUTO env-var here is
# documented with explicit opt-out semantics per AC17 / PLAN-088 W5.2.
#
# Default convention: `0` = OFF (don't fire) / `1` = ON (fire by default).
# Where the conversion's default is opt-IN (AUTO-01, AUTO-08, AUTO-10),
# the env-var defaults to `1`; user can opt out with `0`.
# =============================================================================

# -----------------------------------------------------------------------------
# AUTO-01 — Cache discipline Tier-S /ceo-boot promotion (W1.1)
# Default ON: fires SessionStart Tier-S check; emit cache_discipline_alerted
# when hit-rate < 0.7 floor. Set to 0 to disable.
# -----------------------------------------------------------------------------
CEO_CACHE_DISCIPLINE=1

# -----------------------------------------------------------------------------
# AUTO-02 — First-run wizard SessionStart auto-spawn (W1.2)
# Default OFF: wizard auto-spawns on missing .install-completed.
# Set to 1 to permanently skip wizard.
# -----------------------------------------------------------------------------
CEO_SKIP_WIZARD=0

# -----------------------------------------------------------------------------
# AUTO-03 / AUTO-03b — Estimation calibrator auto-load + phase refinement (W1.3)
# Default OFF: architect skill auto-pulls calibration-baseline.yaml;
# nightly cron updates Bayesian posterior. Set to 1 to disable both.
# CEO_PHASE_REFINE_DISABLE: separate flag — disable phase-refinement only.
# -----------------------------------------------------------------------------
CEO_ESTIMATE_VIBES=0
CEO_PHASE_REFINE_DISABLE=0

# -----------------------------------------------------------------------------
# SEMI-13 — Graceful degradation telemetry emits (W1.4)
# Note: SEMI-13 emits (subagent_findings_partial_drop / anthropic_429_observed /
# git_index_lock_retry / codex_invoke_dispatched) are TELEMETRY-INVARIANT
# per ADR-115 graceful-degradation invariant — they have NO opt-out by
# design (failure-mode telemetry MUST fire on graceful-degradation events).
# Rate-cap at 100/min/action per M-12 prevents log-flood-DoS amplification.
# -----------------------------------------------------------------------------
# CEO_SEMI_13_DISABLE intentionally absent — telemetry-invariant

# -----------------------------------------------------------------------------
# AUTO-04 — Tier-policy 18th Tier-S /ceo-boot check (W2.1)
# Default OFF: tier-policy advisory empty-rate computed every /ceo-boot run;
# emits tier_policy_misrouting_advised when > 10% threshold. Set to 1 to skip.
# -----------------------------------------------------------------------------
CEO_SKIP_TIER_POLICY_CHECK=0

# -----------------------------------------------------------------------------
# AUTO-05 — Multi-model routing resolve() PreToolUse inject (W2.2)
# Default OFF: model_routing.resolve() consulted; injects `model:` into spawn
# payload when absent. Set to 1 to revert to manual model selection.
# -----------------------------------------------------------------------------
CEO_MULTI_MODEL_MANUAL=0

# -----------------------------------------------------------------------------
# AUTO-06 — MCP routing 12-server bundle (W3.1)
# Global kill-switch (overrides per-server). Default OFF.
# Per-server granularity: CEO_MCP_<SERVER>_DISABLE=1 to skip one only.
# Precedence: global=1 overrides per-server; global=0 -> per-server consulted.
# -----------------------------------------------------------------------------
CEO_MCP_ROUTING_DISABLE=0

CEO_MCP_SENTRY_DISABLE=0
CEO_MCP_STRIPE_DISABLE=0
CEO_MCP_VERCEL_DISABLE=0
CEO_MCP_SUPABASE_DISABLE=0
CEO_MCP_CLOUDFLARE_DISABLE=0
CEO_MCP_GMAIL_DISABLE=0
CEO_MCP_DRIVE_DISABLE=0
CEO_MCP_CALENDAR_DISABLE=0
CEO_MCP_AHREFS_DISABLE=0
CEO_MCP_SIMILARWEB_DISABLE=0
CEO_MCP_LUNARCRUSH_DISABLE=0
CEO_MCP_CLAUDE_IN_CHROME_DISABLE=0

# -----------------------------------------------------------------------------
# AUTO-07 — Pair-Rail substantive _decide() SHADOW+DRY_RUN (W4.1)
# Phase pinning: SHADOW (logged-only) / DRY_RUN (advisory-only).
# ACTIVE is INTENTIONALLY REJECTED per M-6 (Phase C deferred to PLAN-090).
# CEO_PAIR_RAIL_DISABLE: global kill-switch (overrides phase pin).
# -----------------------------------------------------------------------------
CEO_PAIR_RAIL_DISABLE=0
CEO_PAIR_RAIL_PHASE=SHADOW

# -----------------------------------------------------------------------------
# AUTO-08 — Batch mode adapter wiring (W4.2)
# Default ON: tournament/runner.py + benchmark dispatch auto-wraps in
# BatchClaudeLiveAdapter on >=10 same-prompt-template spawns.
# Streaming wiring deferred to PLAN-090 (CEO_STREAMING_DISABLE present
# for forward compat).
# -----------------------------------------------------------------------------
CEO_BENCHMARK_BATCH_MODE=1
CEO_STREAMING_DISABLE=0

# -----------------------------------------------------------------------------
# AUTO-09 — Extended thinking auto-dispatch per task class (W2.3)
# Default OFF: _lib/model_routing.resolve() return value sets thinking
# budget per task-class (architect 4k / debate-R2 8k / audit-class 8k).
# Set to 1 to disable thinking auto-dispatch (slash /effort still works).
# -----------------------------------------------------------------------------
CEO_THINKING_AUTO_DISABLE=0

# -----------------------------------------------------------------------------
# AUTO-10 — Sub-agent dispatch general -> specialized promotion (W3.3)
# Default ON: check_agent_spawn rewrites subagent_type=general-purpose
# to specialized archetype on keyword match per team.md ROUTING TABLE.
# Set to 0 to disable promotion.
# -----------------------------------------------------------------------------
CEO_AUTO_SPECIALIZE=1

# -----------------------------------------------------------------------------
# SEMI-11 — Cookbook patterns auto-suggest (W3.2)
# Default OFF: skill-author / plan-draft task signature triggers top-3
# cookbook pattern suggestions. Set to 1 to skip.
# -----------------------------------------------------------------------------
CEO_SKIP_COOKBOOK_HINT=0

# -----------------------------------------------------------------------------
# AUTO-07 / W4.1 — Persona detection (M-10 audit-trail only).
# Optional: set CEO_PERSONA={vibecoder,junior_dev,skeptical_cto,team_member}
# to attribute audit-log signal_source. Persona is AUDITED, not enforced;
# spoofing via env-var cannot escalate privilege.
# -----------------------------------------------------------------------------
# CEO_PERSONA=

# -----------------------------------------------------------------------------
# Extended lifecycle hooks (PLAN-028)
# Default ON. Set to 0 to disable SessionStart/SessionEnd/UserPromptSubmit/Stop.
# -----------------------------------------------------------------------------
CEO_EXTENDED_LIFECYCLE=1
