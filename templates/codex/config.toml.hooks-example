# =========================================================================
# ceo-orchestration -- Codex registration, config.toml VARIANT (EXAMPLE)
# Verified against: codex-cli 0.139.0 (PLAN-155; fixtures + trust semantics
# recorded per that pin -- re-verify on every CLI bump, see the
# substrate-watch item).
# =========================================================================
#
# SHIP EXACTLY ONE REGISTRATION SURFACE. The canonical, installer-shipped
# surface is `.codex/hooks.json` (templates/codex/hooks.json). This file
# documents the equivalent `[hooks]`-in-`config.toml` form because codex
# 0.139 honors BOTH: dual registration WARNS and runs BOTH hooks twice.
# Never install this file as `.codex/config.toml` alongside hooks.json.
# (The non-`.toml` filename is deliberate: a blind directory copy must not
# arm a second registration surface.)
#
# -------------------------------------------------------------------------
# LOUD WARNINGS (read before trusting anything)
# -------------------------------------------------------------------------
# 1. NOTHING in this file (or hooks.json) is enforced until the operator
#    grants /hooks trust. On codex 0.139 an untrusted or modified hook is
#    a SILENT NO-OP: no execution, no warning, exit 0 -- "installed but
#    untrusted" is indistinguishable from healthy at runtime. Run the
#    post-install arming check (PLAN-155 Wave 5) after any change here.
# 2. KILL-SWITCH SURFACE PROTECTION IS ABSENT UNTIL PLAN-155 WAVE 3b
#    LANDS. Until the Wave 3b guard-list + boot-tripwire extension is on
#    main, an agent running under codex can rewrite `.codex/hooks.json`,
#    `.codex/config.toml`, `.codex/rules/ceo.rules`, `requirements.toml`,
#    or the operator `AGENTS.md` and disarm every rail registered here,
#    and the tripwire that should detect it stays silent. Backstop until
#    then: CODEOWNERS + branch protection at push time.
# 3. Trust is keyed to the COMMAND LINE, not to hook code: the /hooks
#    trust hash covers {event, matcher, command, timeout, statusMessage}
#    only. Editing a hook `.py` body does NOT re-prompt trust; editing one
#    byte of a command string flips the hook to `modified` and it silently
#    stops firing. Registration integrity is codex's; hook-body integrity
#    is the framework's (canonical-edit guard over `.claude/hooks/**`).
# 4. Two gates must BOTH hold before a project hook fires:
#      projects."<abs project path>".trust_level = "trusted"
#    in `$CODEX_HOME/config.toml`, AND per-hook trust (interactive /hooks,
#    or a headless `[hooks.state]` entry). If an installer writes trust
#    entries headlessly it MUST print-and-confirm first -- trust is
#    consent, not a config bit (PLAN-155 OQ1 doctrine).
# 5. No speed claim anywhere. The value is governance and auditability.
#
# -------------------------------------------------------------------------
# Placeholder: `{{PROJECT_PATH}}` = absolute path of the target repository
# root (substituted at install time by `install.sh --harness codex`,
# PLAN-155 Wave 5 -- same placeholder vocabulary as the existing
# installer). Codex adds only CODEX_HOME/CODEX_MANAGED_* to the hook
# environment; it does NOT set or expand $CLAUDE_PROJECT_DIR, so commands
# below must carry absolute paths.
# -------------------------------------------------------------------------

# === PreToolUse: edit-time ENFORCED rails ================================
# matcher "apply_patch|Edit|Write": codex file edits arrive as the
# `apply_patch` tool; the host adapter (PLAN-155 Wave 1) parses the patch
# headers into Edit/Write semantics. Residual on every ENFORCED row:
# writes smuggled through complex shell commands (the shell-escape class);
# backstops: the ^Bash$ rail sees the full command string, CODEOWNERS +
# branch protection at push.

[[hooks.PreToolUse]]
matcher = "apply_patch|Edit|Write"

  [[hooks.PreToolUse.hooks]]
  type = "command"
  command = 'env CEO_HOOK_ADAPTER=codex CLAUDE_PROJECT_DIR="{{PROJECT_PATH}}" bash "{{PROJECT_PATH}}/.claude/hooks/_python-hook.sh" check_canonical_edit.py'
  timeout = 5
  statusMessage = "CEO canonical-edit guard [ENFORCED at edit time; residual: shell-escape class] -- NOTHING is enforced until /hooks trust is granted"

  [[hooks.PreToolUse.hooks]]
  type = "command"
  command = 'env CEO_HOOK_ADAPTER=codex CLAUDE_PROJECT_DIR="{{PROJECT_PATH}}" bash "{{PROJECT_PATH}}/.claude/hooks/_python-hook.sh" check_plan_edit.py'
  timeout = 5
  statusMessage = "CEO plan-lifecycle guard [ENFORCED at edit time; residual: shell-escape class]"

  [[hooks.PreToolUse.hooks]]
  type = "command"
  command = 'env CEO_HOOK_ADAPTER=codex CLAUDE_PROJECT_DIR="{{PROJECT_PATH}}" bash "{{PROJECT_PATH}}/.claude/hooks/_python-hook.sh" check_arbitration_kernel.py'
  timeout = 5
  statusMessage = "CEO arbitration-kernel deny [ENFORCED at edit time; residual: shell-escape class]"

# matcher "^Bash$": our hook receives the FULL command string on every
# event that fires and applies our own parser (fail-closed on unparseable
# input, PLAN-152 C4). Residual: codex "doesn't intercept all shell calls
# yet, only the simple ones" -- .codex/rules/ceo.rules is the coarse
# prefix backstop under this rail, never coverage.

[[hooks.PreToolUse]]
matcher = "^Bash$"

  [[hooks.PreToolUse.hooks]]
  type = "command"
  command = 'env CEO_HOOK_ADAPTER=codex CLAUDE_PROJECT_DIR="{{PROJECT_PATH}}" bash "{{PROJECT_PATH}}/.claude/hooks/_python-hook.sh" check_bash_safety.py'
  timeout = 5
  statusMessage = "CEO bash-safety guard [ENFORCED; residual: partial shell interception -- ceo.rules is the coarse prefix backstop]"

# matcher "mcp__.*": MCP tool calls. Residual: MCP arg-shape class (tool
# arguments are server-defined; the guard normalizes what it recognizes
# and fails closed on unparseable security-matcher input).

[[hooks.PreToolUse]]
matcher = "mcp__.*"

  [[hooks.PreToolUse.hooks]]
  type = "command"
  command = 'env CEO_HOOK_ADAPTER=codex CLAUDE_PROJECT_DIR="{{PROJECT_PATH}}" bash "{{PROJECT_PATH}}/.claude/hooks/_python-hook.sh" check_canonical_edit.py'
  timeout = 5
  statusMessage = "CEO canonical-edit guard over MCP tools [ENFORCED at edit time; residual: MCP arg-shape class]"

  [[hooks.PreToolUse.hooks]]
  type = "command"
  command = 'env CEO_HOOK_ADAPTER=codex CLAUDE_PROJECT_DIR="{{PROJECT_PATH}}" bash "{{PROJECT_PATH}}/.claude/hooks/_python-hook.sh" check_arbitration_kernel.py'
  timeout = 5
  statusMessage = "CEO arbitration-kernel deny over MCP tools [ENFORCED at edit time; residual: MCP arg-shape class]"

