# macOS
.DS_Store

# Editors
.idea/
.vscode/
*.swp

# Backup files created by upgrade.sh in target repos
.claude.bak/
.coverage

# materialize-then-finish process artifacts (NOT product): the non-canonical
# staging mirror, the finish-script pre-apply backups, and the one-button finish
# scripts. Per the S238 convention, finish scripts + staging trees are never
# committed. (Globbed so future bundles need no .gitignore change — S241.)
staged/
.plan*-bak/
finish-*.sh

# PLAN-010 Phase 6: accidental onboarding-pack output if someone runs
# admin-invite.py with --out-dir pointing inside the repo tree.
# (The default path is ~/ceo-onboarding-packs/ outside the repo.)
onboarding-pack-*/

# PLAN-012 Phase 1 / Security CRITICAL-2: credentials — keep local only
.env
.env.*
*.env
!.env.example
secrets.json
credentials.json
*.credentials
api-keys.txt

# PLAN-013 Phase 2 / npm install path — local build artifacts.
# scripts/install-npm.sh stages the framework source tree into npm/
# and runs `npm pack` to produce a .tgz tarball for smoke-testing.
# These files are the framework's source tree (already tracked in repo
# root) + the built tarball — neither should be committed inside npm/.
npm/.claude/
npm/SPEC/
npm/scripts/
npm/templates/
npm/VERSION
npm/PROTOCOL.md
npm/LICENSE
npm/*.tgz
npm/*.tgz.sha256
npm/node_modules/

# PLAN-019 P2-SEC-H: MCP HMAC shared-secret store — never commit.
# install.sh creates this dir with chmod 700; auth.load_secret() rejects
# files that are not exactly 0o600. Adopters and the framework dogfood
# install both stash client_id.key files here.
state/mcp_client_secrets/

# PLAN-128 turbo accelerator runtime markers (e.g. turbo-initialized),
# written by the SessionStart hook. Pure per-session runtime state — never
# framework source.
.claude/state/turbo/

# PLAN-044 audit-v2 C5-P0-03: per-machine local Claude Code permission
# overrides (`claude /permissions`). This file is written by Claude Code
# at runtime and is intentionally per-developer / per-machine — it MUST
# NOT be committed. The shared, repo-wide settings live in
# `.claude/settings.json`.
.claude/settings.local.json

# PLAN-045 Phase D: FileLock runtime artifacts from skill-patch-apply.py
# (sibling to SKILL.md.shadow.md during apply; released on normal exit).
# Never committed — runtime state only.
*.shadow.md.lock

# PLAN-050: kernel-batch transactional .bak files (created during apply,
# removed on success, retained on failure for debug). Never commit.
*.py.bak
*.py.bak.*

# Session 60 parallel-terminal runtime scheduler lock (not session artifact).
# Written by /schedule or routine runtime; ephemeral.
.claude/scheduled_tasks.lock

# Sub-agent worktrees (transient git worktrees from Agent isolation:worktree).
# Created by S82 paralelo and similar parallel-track sprints; ephemeral.
.claude/worktrees/

# PLAN-078 Wave 2 — Reality Ledger detector #7 calibration CSV.
# Local advisory output — drift factors per closed plan; never committed.
.claude/scripts/local/calibration-history.csv

# PLAN-078 Wave 4 — dependency graph viz output (regenerated on demand).
# Standalone HTML+SVG; renders 70+ plans offline-safe. Never committed.
# Output lives under scripts/local/ (not under .claude/plans/) so it doesn't
# trip the PLAN-SCHEMA §1 filename validator.
.claude/scripts/local/dependency-graph.html

# PLAN-082 Codex collateral finding — `.claude/cache/` is repo-local
# ephemeral cache (formerly used by hook-test baseline; now reserved for
# future auto-fill schemes). MUST stay out of git: per-machine state.
.claude/cache/

# coverage.py JSON output (`coverage json -o coverage.json`) — local-only
# test artifact (~9MB), regenerated on every test run.
coverage.json
.coverage
.coverage.*
htmlcov/

# S125+ OWNER-CEREMONY single-script idempotency state — each ceremony
# script writes state-machine markers (A_fresh / B_signed / C_applied /
# D_committed / E_pushed / I_committed / I_tagged / J_pushed) into its
# parent PLAN-NNN/.ceremony-state/ subdir so re-runs are idempotent.
# Pure operational state; not source. Per-plan-dir glob catches both
# PLAN-NNN/ + PLAN-NNN-FOLLOWUP/ (PLAN-SCHEMA §1.4). Codified S127.
.claude/plans/*/.ceremony-state/
# S130 — PLAN-096 ceremony also writes top-level .ceremony-state/<plan-id>/
# markers (RUN-ME.sh wrapper convention). Same scope as above — operational
# state, not source.
.ceremony-state/

# PLAN-097 Wave A.7 — corpus expansion (regenerated on demand)
.claude/scripts/fixtures/corpus-expansion/

# PLAN-112 audit night-run transient state (regenerated by runtime-wrapper.sh):
# project-clones inflate sandbox/ to 80+ MB each; wrapper recreates on demand.
# Fixtures + receipts + diffs ARE committed for reproducibility — only the
# clones + caches are excluded.
# Wildcards apply to ANY depth (sub-agents sometimes nest sandbox dirs):
.claude/plans/PLAN-112/sandbox/**/project-clone/
.claude/plans/PLAN-112/sandbox/**/xdg-cache/
.claude/plans/PLAN-112/sandbox/**/pip-cache/
.claude/plans/PLAN-112/sandbox/**/npm-cache/
# Bulky wrapper diff manifests (each home-claude.shasum is 24,691 lines;
# the actionable signal is in wrapper-receipt.json. Keep wrapper-receipt +
# findings-raw.jsonl + sandbox-logs/{stdout,stderr}.txt + scratch/*).
.claude/plans/PLAN-112/sandbox/**/pre-diff/
.claude/plans/PLAN-112/sandbox/**/post-diff/
.claude/plans/PLAN-112/sandbox/**/home/
.claude/plans/PLAN-112/sandbox/**/audit-log/
.claude/plans/PLAN-112/sandbox/**/tmp/
.claude/plans/PLAN-112/sandbox/**/xdg-config/
.claude/plans/PLAN-112/sandbox/**/xdg-data/
# Coverage-ledger filelock leftover (fcntl flock sibling)
.claude/plans/PLAN-112/coverage-ledger.json.lock

# S158 — OpenAI Codex app local artifacts. The Owner runs Codex inside the repo
# as a dev tool; it writes .codex/ + .agents/ (transcripts/state, ~229k lines).
# Pure per-developer tool state — never framework source.
# S261 (PLAN-153 Wave A): AGENTS.md is now VERSIONED framework source — the
# review contract read by the cross-LLM pair-rail (freshness-checked by
# .claude/scripts/check-agents-md.py). It is no longer ignored here.
.codex/
.agents/

# S159 — Python bytecode + pytest cache (never versioned; the repo had no
# global ignore for these, so a `git add <dir>` over a test tree could drag
# __pycache__ in — it did once into v1.43.0's pre-clean commit, now removed).
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# S159 — PLAN-112 apply-source staging mirrors (full-file copies used to drive
# ceremony applies; the shipped code lives in git at v1.42.0/v1.43.0, so these
# are spent build artifacts). Kept on disk pending Owner cleanup but ignored so
# they can't be accidentally `git add`-ed (the 20714-line footgun). NOT the
# sandbox (.claude/plans/PLAN-112/sandbox — 267 tracked files, left as-is).
.claude/plans/PLAN-112/staging/

# S164 — mutmut mutation-test cache artifacts. mutmut writes a .mutmut-cache
# SQLite database during mutation runs; it is per-machine state and must never
# be committed.
.mutmut-cache
**/.mutmut-cache
*.mutmut-cache

# Federation live peer registry — operator-created at the documented path;
# contains live peer endpoints/keys and must NEVER be committed (PLAN-114 F-1.7).
# The committed peers.example.yaml template is intentionally tracked.
.claude/data/federation/peers.yaml
dist/
